# Copy to .env and fill in. .env is gitignored.
#
# VS Code Marketplace personal access token.
# https://marketplace.visualstudio.com/manage → Personal Access Tokens.
# Scope: Marketplace → Manage.
VSCE_PAT=

# Open VSX access token (Cursor, VSCodium, Windsurf, Gitpod).
# https://open-vsx.org → avatar → Settings → Access Tokens.
OVSX_PAT=
